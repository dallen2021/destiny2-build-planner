# Bungie application settings
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# App URLs
CLIENT_URL=http://localhost:3000

# Session and admin settings for the legacy Express app.
# The rebuilt Vercel app should replace this with its chosen session store.
SESSION_SECRET=
ADMIN_API_KEY=

# Legacy local/session store. Do not expose MongoDB publicly in production.
MONGODB_URI=mongodb://localhost:27017/d2-builder

# Optional Firecrawl key for regenerating rendered external docs snapshots.
# Do not commit real API keys.
FIRECRAWL_API_KEY=
