# Bungie application settings
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# Optional. Normally inferred from the current request origin.
# Only set this when it matches the exact origin users are logging in from.
# OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App URLs
APP_URL=http://localhost:3000

# Used to encrypt HTTP-only session cookies. Use a long random value.
SESSION_SECRET=

# Optional Firecrawl key for regenerating rendered external docs snapshots.
# Do not commit real API keys.
FIRECRAWL_API_KEY=
